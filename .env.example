# === Nginx ===
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# === Production ===
APP_IMAGE=ghcr.io/<owner>/<image>:<tag>
BACKUP_DIR=/backups
DEPLOY_DIR=/opt/maple-utility

# === MCP (Claude Code PostgreSQL MCP 연결용) ===
DATABASE_URL=postgresql://maple_user:<DB_PASSWORD값>@localhost:<DB_PORT값>/maple
