# === Database ===
DB_PASSWORD=
DB_PORT=5432
DATABASE_URL=postgresql://maple_user:<DB_PASSWORD>@localhost:5432/maple

# === Redis ===
REDIS_PORT=6379

# === Application ===
APP_PORT=8080
APP_IMAGE=ghcr.io/<owner>/<image>:<tag>
APP_CORS_ALLOWED_ORIGINS=https://<frontend-domain>,http://localhost:3000

# === JWT ===
JWT_SECRET=

# === Kakao OAuth ===
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=https://<backend-domain>/api/v1/auth/kakao/callback
KAKAO_TOKEN_URI=https://kauth.kakao.com/oauth/token
KAKAO_USER_INFO_URI=https://kapi.kakao.com/v2/user/me

# === Nexon Open API ===
NEXON_API_KEY_SECRET=
NEXON_CHARACTER_LIST_URI=https://open.api.nexon.com/maplestory/v1/character/list
NEXON_CHARACTER_BASIC_URI=https://open.api.nexon.com/maplestory/v1/character/basic
NEXON_CHARACTER_SCHEDULER_URI=https://open.api.nexon.com/maplestory/v1/character/scheduler

# === Nginx / SSL ===
SERVER_NAME=<backend-domain>
LETSENCRYPT_EMAIL=
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# === Deploy / Backup ===
DEPLOY_DIR=/opt/maple-utility
BACKUP_DIR=/backups
