# === Database ===
DB_PASSWORD=
DB_PORT=5432

# === Redis ===
REDIS_PORT=6379

# === Application ===
APP_PORT=8080
JWT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_REDIRECT_URI=
KAKAO_CLIENT_SECRET=
KAKAO_TOKEN_URI=https://kauth.kakao.com/oauth/token
KAKAO_USER_INFO_URI=https://kapi.kakao.com/v2/user/me
NEXON_CLIENT_ID=
NEXON_REDIRECT_URI=
NEXON_CLIENT_SECRET=
NEXON_TOKEN_URI=
NEXON_USER_INFO_URI=
NEXON_API_KEY_SECRET=
